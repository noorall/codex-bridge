<idea-plugin>
    <id>com.noorall.codex.bridge</id>
    <name>Codex Bridge</name>
    <vendor url="https://github.com/noorall" email="noorall.orz@gmail.com">Noorall</vendor>

    <description><![CDATA[
        <div style="width: 100%; max-width: 100%; box-sizing: border-box; white-space: normal; overflow-wrap: anywhere; word-break: break-word;">
            <p style="max-width: 100%; white-space: normal; overflow-wrap: anywhere; word-break: break-word;">
                Start Codex CLI from JetBrains IDEs with project-specific context for Codex /ide, keeping Codex in the terminal while the IDE supplies the active file, selection, and open tabs.
            </p>
            <p style="margin: 6px 0 4px 0;"><b>Feature</b></p>
            <ul style="margin: 0 0 8px 0; padding-left: 0; list-style-position: inside; max-width: 100%; white-space: normal; overflow-wrap: anywhere; word-break: break-word;">
                <li>Launch Codex from the toolbar icon or Tools | Start Codex.</li>
                <li>Enable Codex /ide context automatically after the Codex terminal is ready.</li>
            </ul>
            <p style="margin: 10px 0 4px 0;"><b>Configuration</b></p>
            <p style="max-width: 100%; white-space: normal; overflow-wrap: anywhere; word-break: break-word;">
                Configure the Codex command and IDE context behavior in Settings | Tools | Codex Bridge.
            </p>
            <p style="margin: 10px 0 4px 0;"><b>Open Source</b></p>
            <p style="max-width: 100%; white-space: normal; overflow-wrap: anywhere; word-break: break-word;">
                GitHub: <a href="https://github.com/noorall/codex-bridge" style="overflow-wrap: anywhere; word-break: break-word;">https://github.com/noorall/codex-bridge</a>
            </p>
        </div>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="com.noorall.codex.bridge.CodexProjectActivity"/>
        <applicationConfigurable
                id="codex.bridge.settings"
                parentId="tools"
                instance="com.noorall.codex.bridge.CodexSettingsConfigurable"
                displayName="Codex Bridge"/>
    </extensions>

    <actions>
        <action
                id="com.noorall.codex.bridge.LaunchCodexAction"
                class="com.noorall.codex.bridge.LaunchCodexAction"
                text="Start Codex"
                description="Start Codex with JetBrains IDE context"
                icon="/icons/codex-bridge.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
